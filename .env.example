# SkillHub 前端环境变量示例
# 复制此文件为 .env 并填入真实值
# .env 文件不会被提交到 git

# ==============================================
# 前端 API 配置
# ==============================================

# 前端 API 地址
VITE_API_URL=http://localhost:3001/api

# ==============================================
# 后端服务配置
# ==============================================

# 管理员密码（必填，用于管理后台登录验证）
ADMIN_PASSWORD=123456