# SkillHub 环境变量示例
# 复制此文件为 .env 并填入真实值
# .env 文件不会被提交到 git

# ==============================================
# 前端配置
# ==============================================

# 前端 API 地址
VITE_API_URL=http://localhost:3001/api

# 管理员密码（用于管理后台登录）
VITE_ADMIN_PASSWORD=admin123

# ==============================================
# 后端配置
# ==============================================

# 后端服务主机
HOST=localhost

# 后端服务端口
PORT=3001

# 技能数据保存目录（相对项目根目录或绝对路径）
# 不填则默认为 data/skills
DATA_DIR=
