# SkillHub 环境变量示例
# 复制此文件为 .env 并填入真实值
# .env 文件不会被提交到 git

# ==============================================
# 前端配置
# ==============================================

# 前端 API 地址
VITE_API_URL=http://localhost:3001/api

# 管理员密码（用于管理后台登录，仅后端使用）
ADMIN_PASSWORD=123456789

# ==============================================
# GitHub 同步配置
# ==============================================

# GitHub API 并发请求数（建议 3-5，避免触发 Rate Limit）
VITE_GITHUB_CONCURRENT_REQUESTS=3

# 请求失败时最大重试次数
VITE_GITHUB_MAX_RETRIES=3

# 请求间隔（毫秒），避免 GitHub Rate Limit
VITE_GITHUB_RATE_LIMIT_DELAY=1000

# ==============================================
# 后端配置
# ==============================================

# 后端服务主机
HOST=localhost

# 后端服务端口
PORT=3001

# 技能数据保存目录（相对项目根目录或绝对路径）
# 不填则默认为 data/skills
DATA_DIR=
